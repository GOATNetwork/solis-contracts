    "hardhat": "^3.4.5",
    "typescript": "~5.8.0",
    "viem": "^2.48.11"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  },
  "engines": {
    "node": ">=24"
  }
}
